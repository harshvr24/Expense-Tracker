{
  "name": "expense-tracker-vercel",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack expense tracker app deployable on Vercel",
  "scripts": {
    "dev": "concurrently \"cd frontend && npm start\" \"vercel dev\"",
    "build": "cd frontend && npm run build",
    "start": "node server.js",
    "install-all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  },
  "engines": {
    "node": "20.x",
    "npm": "10.x"
  }
}
