{
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "npm install",
  "outputDirectory": "frontend/build",
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "^(?!/?api).*",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
