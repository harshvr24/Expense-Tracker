{
  "installCommand": "npm ci",
  "buildCommand": "npm --prefix=frontend ci && npm --prefix=frontend run build",
  "outputDirectory": "frontend/build",
  "routes": [
    {
      "src": "^/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "^(?!/?api).*",
      "dest": "/index.html"
    }
  ]
}
